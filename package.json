{
  "name": "aeocanon",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n velite,next -c magenta,green \"velite dev\" \"next dev\"",
    "build": "velite build --strict && next build",
    "build:content": "velite build --strict",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,mjs,css,md,mdx,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,mjs,css,md,mdx,json}\"",
    "db:types": "supabase gen types typescript --project-id YOUR_PROJECT_ID --schema public > src/lib/db/types.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/react": "^3.0.199",
    "@base-ui/react": "^1.5.0",
    "@calcom/embed-react": "^1.5.3",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "ai": "^6.0.197",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "schema-dts": "^2.0.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.2.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "velite": "^0.3.1"
  }
}
