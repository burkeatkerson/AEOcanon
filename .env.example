# Public base URL of the site. Used for canonical tags, sitemap, OG, llms.txt, RSS.
# Override per-environment (e.g. preview deploys) without code changes.
NEXT_PUBLIC_SITE_URL=https://aeocanon.com

# === Audit tool (all keys server-side only) ===
ANTHROPIC_API_KEY=                 # Claude, via the Vercel AI SDK. Server only.
PAGESPEED_API_KEY=                 # Google PageSpeed Insights API key. Server only.
AUDIT_USER_AGENT=AEOCanonAuditBot  # User-agent sent when fetching audited sites.

# === Supabase (application data; kept separate from MDX content) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=         # Server only. Bypasses RLS for trusted server writes.

# === Booking ===
NEXT_PUBLIC_CALCOM_LINK=           # e.g. "aeocanon/intro-call" (legacy Cal.com seam)
# Calendly scheduling link — the primary "book a call" CTA across the site and
# the inline embed on /contact. Has a safe default in src/lib/site.ts.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/atkerson/phonecall

# === Contact form (server-only; delivers lead emails via Resend) ===
# RESEND_API_KEY (below) must be set for the form to actually send. Until it is,
# the form validates and steers prospects to booking instead of erroring.
CONTACT_TO_EMAIL=burkelatkerson@gmail.com  # Where inquiries are delivered. Never exposed client-side.
CONTACT_FROM_EMAIL=                        # Verified Resend sender, e.g. "AEO Canon <hello@aeocanon.com>". Falls back to AUDIT_FROM_EMAIL, then Resend's onboarding sender.

# === 8-Pillar Scorecard ===
# Optional outbound webhook fired (fire-and-forget) when a scorecard is completed.
# Receives { type, email, segment, playbookUrl, tier, percent, ... } — wire this
# to your email automation / drip later. Unset = no-op; on-screen results work
# either way. Uses ANTHROPIC_API_KEY (above) for the on-screen write-up and the
# public Supabase `playbooks` storage bucket (migration 0002) for the PDFs.
SCORECARD_WEBHOOK_URL=

# === Admin section + CRM (server-only; see ADMIN_CRM.md) ===
# The /login admin gate: one password + an HMAC-signed session cookie. No Supabase
# Auth user. Required only when using the admin area / automation engine.
ADMIN_PASSWORD=                    # the single admin login password
ADMIN_SESSION_SECRET=              # long random string; signs the admin session cookie
CRON_SECRET=                       # bearer secret for /api/cron/tick. On Vercel, setting this
                                   # makes Vercel Cron send it automatically. Also used for manual curl.
MARKETING_FROM_EMAIL=              # verified Resend sender for drips/broadcasts; falls back to CONTACT_FROM_EMAIL
UNSUBSCRIBE_SECRET=                # optional; signs unsubscribe tokens. Falls back to ADMIN_SESSION_SECRET.
RESEND_WEBHOOK_SECRET=             # optional; verifies Resend event webhooks at /api/webhooks/resend

# === Deferred (placeholders; packages installed at their feature phase) ===
RESEND_API_KEY=                    # transactional email + audit PDF delivery + CRM automation sends
AUDIT_FROM_EMAIL=                  # e.g. "reports@aeocanon.com"
UPSTASH_REDIS_REST_URL=            # durable rate limiting (optional; in-memory default used otherwise)
UPSTASH_REDIS_REST_TOKEN=
