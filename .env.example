# Public base URL of the site. Used for canonical tags, sitemap, OG, llms.txt, RSS.
# Override per-environment (e.g. preview deploys) without code changes.
NEXT_PUBLIC_SITE_URL=https://aeocanon.com

# === Audit tool (all keys server-side only) ===
ANTHROPIC_API_KEY=                 # Claude, via the Vercel AI SDK. Server only.
PAGESPEED_API_KEY=                 # Google PageSpeed Insights API key. Server only.
AUDIT_USER_AGENT=AEOCanonAuditBot  # User-agent sent when fetching audited sites.

# === Supabase (application data; kept separate from MDX content) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=         # Server only. Bypasses RLS for trusted server writes.

# === Booking ===
NEXT_PUBLIC_CALCOM_LINK=           # e.g. "aeocanon/intro-call"

# === Deferred (placeholders; packages installed at their feature phase) ===
RESEND_API_KEY=                    # transactional email + audit PDF delivery
AUDIT_FROM_EMAIL=                  # e.g. "reports@aeocanon.com"
UPSTASH_REDIS_REST_URL=            # durable rate limiting (optional; in-memory default used otherwise)
UPSTASH_REDIS_REST_TOKEN=
